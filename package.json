  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nodestrap/element.git"
  },
  "keywords": [
    "html",
    "element",
    "dom",
    "manipulation"
  ],
  "author": "nodestrap, heymarco",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nodestrap/element/issues"
  },
  "homepage": "https://github.com/nodestrap/element#readme",
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
