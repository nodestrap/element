{
  "name": "@nodestrap/element",
  "version": "2.0.14",
  "description": "A base class for manipulating common HTML element.",
  "dependencies": {
    "@nodestrap/border": "^2.0.0",
    "@nodestrap/colors": "^2.0.1",
    "@nodestrap/sass-class-template": "^2.0.2",
    "@nodestrap/sass-selector": "^2.0.1",
    "@nodestrap/spacer": "^2.0.0",
    "@nodestrap/typography": "^2.0.0",
    "react": "^17.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.11.9",
    "@testing-library/react": "^11.2.3",
    "@testing-library/user-event": "^12.6.0",
    "@types/jest": "^26.0.20",
    "@types/node": "^14.14.21",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "react-dom": "^17.0.1",
    "react-scripts": "^4.0.1",
    "tilde-sass": "^1.0.0",
    "typescript": "^4.1.3"
  },
  "scripts": {
